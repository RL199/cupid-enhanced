{
    "manifest_version": 3,
    "name": "Cupid Enhanced",
    "version": "1.3.0",
    "description": "Enhances the OkCupid platform for better usability and features.",
    "icons": {
        "16": "assets/icons/icon-16.png",
        "32": "assets/icons/icon-32.png",
        "48": "assets/icons/icon-48.png",
        "128": "assets/icons/icon-128.png"
    },
    "permissions": ["storage", "tabs", "cookies"],
    "host_permissions": ["https://www.okcupid.com/*", "https://*.okcupid.com/*", "https://e2p-okapi.api.okcupid.com/*"],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon-16.png",
            "32": "assets/icons/icon-32.png",
            "48": "assets/icons/icon-48.png",
            "128": "assets/icons/icon-128.png"
        },
        "default_title": "Cupid Enhanced Settings"
    },
    "background": {
        "service_worker": "scripts/background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.okcupid.com/*"],
            "js": ["scripts/api-interceptor.js"],
            "run_at": "document_start",
            "all_frames": true,
            "world": "MAIN"
        },
        {
            "matches": ["https://*.okcupid.com/*"],
            "js": [
                "scripts/shared/settings.js",
                "scripts/shared/graphql-operations.js",
                "scripts/shared/selectors.js",
                "scripts/shared/styles.js",
                "scripts/content/api-helpers.js",
                "scripts/content/graphql-queries.js",
                "scripts/content/photo-upload.js",
                "scripts/content/ui-enhancements.js",
                "scripts/content/doubletake-buttons.js",
                "scripts/content/content-main.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ]
}
